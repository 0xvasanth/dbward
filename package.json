{
  "name": "dbward",
  "version": "0.1.0",
  "description": "MCP server for PostgreSQL, MySQL, SQLite, MSSQL and MongoDB with per-table allowlist enforcement",
  "license": "MIT",
  "author": "Vasanth",
  "homepage": "https://github.com/0xvasanth/dbward#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xvasanth/dbward.git"
  },
  "bugs": {
    "url": "https://github.com/0xvasanth/dbward/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "database",
    "postgres",
    "mysql",
    "sqlite",
    "mssql",
    "mongodb",
    "allowlist",
    "security"
  ],
  "type": "module",
  "bin": {
    "dbward": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "mongodb": "^7.1.1",
    "mssql": "^12.3.1",
    "mysql2": "^3.22.1",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "oxlint": "^0.15.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20"
  }
}
